# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=onfis_db
DB_USER=postgres
DB_PASSWORD=postgres123

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=86400000

# API Gateway
API_GATEWAY_URL=http://localhost:8080

# Frontend URLs
MAIN_WEBAPP_URL=http://localhost:3000
LANDING_PAGE_URL=http://localhost:3001

# Backend Service URLs
USER_SERVICE_URL=http://localhost:8081
PROJECT_SERVICE_URL=http://localhost:8082
POSITION_SERVICE_URL=http://localhost:8083
ADMIN_SERVICE_URL=http://localhost:8084
CHAT_SERVICE_URL=http://localhost:8085
ANNOUNCEMENT_SERVICE_URL=http://localhost:8086

# CORS Origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Environment
NODE_ENV=development
SPRING_PROFILES_ACTIVE=dev

# Multi-tenancy
DEFAULT_TENANT_ID=default-company

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=/uploads
